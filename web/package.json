{
  "name": "perfect-utilitares-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "setup:env": "node scripts/ensure-env.mjs",
    "sync:mediapipe": "node scripts/sync-mediapipe.mjs",
    "clean:optional-wasm": "node scripts/clean-optional-wasm.mjs",
    "prebuild": "npm run setup:env && npm run sync:mediapipe && npm run prisma:generate",
    "build": "next build --turbopack",
    "postbuild": "npm run clean:optional-wasm",
    "start": "node server.js",
    "test": "vitest run",
    "pretypecheck": "npm run prisma:generate",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:deploy": "prisma migrate deploy && npm run prisma:seed",
    "build:deploy": "npm run build && npm run db:deploy"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@mediapipe/face_detection": "0.4.1646425229",
    "@prisma/client": "6.19.3",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@sentry/nextjs": "10.52.0",
    "@sentry/profiling-node": "10.52.0",
    "@tanstack/react-query": "5.100.9",
    "@types/pdfkit": "^0.17.6",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "0.7.1-canary.2",
    "clsx": "2.1.1",
    "csv-parse": "6.2.1",
    "dotenv": "17.4.2",
    "jszip": "^3.10.1",
    "lucide-react": "1.14.0",
    "next": "16.2.5",
    "next-auth": "5.0.0-beta.31",
    "pdfkit": "^0.18.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-easy-crop": "^5.5.7--canary.642.b63bd1a.0",
    "react-hook-form": "7.75.0",
    "read-excel-file": "9.0.9",
    "recharts": "3.8.1",
    "resend": "^6.12.3",
    "sharp": "^0.34.5",
    "tailwind-merge": "3.5.0-dev.c719d45eb836accd1fd4b04c9d2e65e8f342a025",
    "zod": "4.5.0-canary.20260504T180558"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "prisma": "6.19.3",
    "tailwindcss": "4.2.4",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "5.0.0-beta.2"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
